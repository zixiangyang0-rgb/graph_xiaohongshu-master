# =============================================================================
# Git 忽略文件配置
# =============================================================================
#
# 通俗理解：告诉 Git"这些文件不要管"，比如密码文件、临时文件、构建产物。
#
# 字段说明：
#   *.pyc         忽略所有 .pyc 字节码文件
#   __pycache__/  忽略缓存目录
#   # 注释        说明用途


# Python 编译文件
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.install.cfg
*.egg
MANIFEST

# PyInstaller 打包文件
*.manifest
*.spec

# 测试 & 覆盖率
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# 翻译文件
*.mo
*.pot

# 环境变量（包含敏感信息）
.env.local
.env.*.local
!.env.example

# IDE 配置
.idea/
*.swp
*.swo
*~
.DS_Store
.vscode/
*.code-workspace

# 日志和数据库
*.log
logs/
*.sqlite
*.sqlite3
*.db

# AI 生成的图片（运行时产生）
static/images/generated/
generated_images/

# 前端
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.node_repl_history
*.tsbuildinfo
frontend/node_modules/
dist/
*.local

# LangGraph 检查点
checkpoints/
